          {
            "name": "nrp",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Nrp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
