      "get": {
        "summary": "Video Feed",
        "operationId": "video_feed_video_feed_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
